# ─────────────────────────────────────────────────────────────────────────────
# AI TestPilot X — Streamlit Cloud Secrets Template
# ─────────────────────────────────────────────────────────────────────────────
# HOW TO USE:
#   In Streamlit Cloud → App Settings → Secrets
#   Copy and paste the content below, filling in your values.
#   DO NOT commit secrets.toml to git.
# ─────────────────────────────────────────────────────────────────────────────

# Required — Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY = "AIzaSy..."

# Optional — LangSmith tracing (https://smith.langchain.com)
LANGSMITH_API_KEY = ""
LANGSMITH_PROJECT = "ai-testpilot-x"
LANGSMITH_TRACING = false

# Execution mode — always MOCK on cloud (no real browser available)
EXECUTION_MODE = "MOCK"

# Database — SQLite works fine on Streamlit Cloud (ephemeral storage)
DB_URL = "sqlite:///./testpilot.db"

# ChromaDB vector store path
CHROMA_PATH = "./chroma_db"

# App settings
APP_ENV = "production"
LOG_LEVEL = "INFO"
MAX_AGENT_RETRIES = 2

