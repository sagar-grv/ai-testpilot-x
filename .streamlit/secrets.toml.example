# Copy this file to .streamlit/secrets.toml and fill in values for Streamlit Cloud deployment
GEMINI_API_KEY = "your_gemini_api_key_here"
LANGSMITH_API_KEY = ""
LANGSMITH_TRACING = false
EXECUTION_MODE = "MOCK"
DB_URL = "sqlite:///./testpilot.db"
CHROMA_PATH = "./chroma_db"
APP_ENV = "production"
LOG_LEVEL = "INFO"
